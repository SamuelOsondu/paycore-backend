# Application
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Database
DATABASE_URL=postgresql+asyncpg://paycore:paycore@localhost:5432/paycore
SYNC_DATABASE_URL=postgresql+psycopg2://paycore:paycore@localhost:5432/paycore
TEST_DATABASE_URL=postgresql+asyncpg://paycore:paycore@localhost:5432/paycore_test

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=1

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=paycore-kyc-documents

# KYC Limits (NGN)
KYC_TIER0_DAILY_FUNDING_LIMIT=10000
KYC_TIER1_DAILY_LIMIT=50000
KYC_TIER2_DAILY_LIMIT=500000

# Payout
MOCK_PAYOUT=false

# Celery
CELERY_WORKER_CONCURRENCY=4
